# API Keys 模板
# 复制此文件为 ~/.claude/.env 并填入实际的 API keys
# .env 文件不会上传到 git

# ============ AI Provider ============
# Claude/Anthropic
ANTHROPIC_AUTH_TOKEN=your_anthropic_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI (for Codex)
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ============ MCP Services ============
# GitHub
GITHUB_TOKEN=your_github_token_here

# Firecrawl (Web Scraping)
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Supabase
SUPABASE_PROJECT_REF=your_project_ref_here

# ============ Optional Services ============
# Parallel AI (Web Search)
PARALLEL_API_KEY=your_parallel_key_here

# OpenRouter (Perplexity Search)
OPENROUTER_API_KEY=your_openrouter_key_here

# Database
DATABASE_URL=postgresql://user:pass@localhost/db

# Neo4j (Vector Search)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# RunPod
RUNPOD_API_KEY=your_runpod_key_here

# ============ Paths ============
# Projects directory (for filesystem MCP)
PROJECTS_DIR=~/projects

# ============ OpenCode ============
OPENCODE_MODEL=claude-sonnet-4-20250514

# ============ Codex ============
CODEX_MODEL=gpt-5.4
