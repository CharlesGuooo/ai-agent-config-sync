# API Keys 模板
# 复制此文件为 ~/.claude/.env 并填入实际的 API keys
# .env 文件不会上传到 git

# ============ AI Provider ============
# Claude/Anthropic
ANTHROPIC_AUTH_TOKEN=your_anthropic_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI (for Codex)
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ============ MCP Services ============
# GitHub
GITHUB_TOKEN=your_github_token_here

# Brave Search (Web Search - Free tier: 2000 queries/month)
BRAVE_API_KEY=your_brave_api_key_here

# Supabase (Access Token from Dashboard > Account Settings > Access Tokens)
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here

# Expo MCP Token
EXPO_MCP_TOKEN=your_expo_mcp_token_here

# ============ Optional Services ============
# Parallel AI (Web Search)
PARALLEL_API_KEY=your_parallel_key_here

# OpenRouter (Perplexity Search)
OPENROUTER_API_KEY=your_openrouter_key_here

# Database
DATABASE_URL=postgresql://user:pass@localhost/db

# Neo4j (Vector Search)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# RunPod
RUNPOD_API_KEY=your_runpod_key_here

# ============ Paths ============
# Home directory (for filesystem MCP)
HOME=~

# ============ OpenCode ============
OPENCODE_MODEL=claude-sonnet-4-20250514

# ============ Codex ============
CODEX_MODEL=gpt-5.4
